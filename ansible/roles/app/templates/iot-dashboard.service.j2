[Unit]
Description=IoT Monitor Streamlit Dashboard
After=network.target iot-server.service

[Service]
Type=simple
User={{ app_user }}
WorkingDirectory={{ app_dir }}/client
ExecStart={{ app_dir }}/client/.venv/bin/streamlit run app.py --server.port 8501 --server.address 0.0.0.0
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
